# ─────────────────────────────────────────────────────────────
# PlantiumAI Web — variáveis de ambiente
# Copie para `.env.local` (dev) e configure as mesmas na Vercel (Production/Preview).
# NUNCA commite valores reais.
# ─────────────────────────────────────────────────────────────

# Neon Postgres — connection string com pooling (sufixo -pooler) p/ runtime serverless.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Neon SEM pooling — usada só por migrações do drizzle-kit (DDL).
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Auth.js — segredo de sessão. Gere com: openssl rand -base64 32
AUTH_SECRET="troque-por-um-segredo-aleatorio-de-32-bytes"

# URL canônica do app (na Vercel é injetada automaticamente; defina em dev).
AUTH_URL="http://localhost:3000"

# Segredo p/ derivar o hash dos tokens de firmware (HMAC). Gere com: openssl rand -base64 32
DEVICE_TOKEN_PEPPER="troque-por-outro-segredo-aleatorio"

# ── Email transacional (reset de senha) — Resend ───────────────
# resend.com → API Keys. Sem isso, o link de reset só é registrado no log do servidor.
RESEND_API_KEY=""
# Remetente. Use um domínio verificado no Resend p/ enviar a qualquer email;
# com onboarding@resend.dev o envio (modo teste) só chega ao email da sua conta Resend.
EMAIL_FROM="PlantiumAI <onboarding@resend.dev>"

# ── Clima ──────────────────────────────────────────────────────
# Estação automática do INMET (A002 = Goiânia/GO). Se o INMET falhar, cai p/ Open-Meteo (sem chave).
INMET_STATION="A002"

# ── Google OAuth (DESATIVADO — botão de login é só visual por enquanto) ──
# Para habilitar: criar OAuth Client no Google Cloud + redirect /api/auth/callback/google
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""
