# ============================================
# PlantiuIA — Configuração de Ambiente
# ============================================
# Copie este arquivo para .env e preencha os valores

# --- Modo de IA ---
# Opções: local_only, api_only, hybrid_prefer_api, hybrid_prefer_local, smart_failover
AI_MODE=local_only

# --- Modelo Local GGUF (IA Própria) ---
# Deixe vazio para auto-detectar qualquer .gguf em backend/models_ai/
LOCAL_MODEL_PATH=
LOCAL_MODEL_THREADS=0
LOCAL_MODEL_CONTEXT=4096
LOCAL_MODEL_GPU_LAYERS=0

# --- Ollama (IA Local alternativa) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2-vision
OLLAMA_TEXT_MODEL=llama3.2

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# --- Google Gemini ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- Meteorologia ---
OPENWEATHER_API_KEY=
OPENWEATHER_CITY=São Paulo
OPENWEATHER_COUNTRY=BR

# --- Servidor ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
DEBUG=true

# --- Banco de Dados ---
DATABASE_URL=sqlite+aiosqlite:///./data/plantiu.db

# --- Circuit Breaker ---
CB_FAILURE_THRESHOLD=3
CB_RECOVERY_TIMEOUT=60
CB_EXPECTED_EXCEPTION_CODES=429,500,502,503,504
